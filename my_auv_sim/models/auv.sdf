<?xml version="1.0"?>
<sdf version="1.6">
  <model name="tethys">
    <pose>0 0 2 0 0 0</pose> <!-- Set initial position above water -->

    <!-- Plugins -->
    <plugin name="buoyancy" filename="libbuoyancy_plugin.so">
      <link name="base_link">
        <fluid_density>1000</fluid_density> <!-- Water density (kg/m^3) -->
        <buoyancy_force>true</buoyancy_force>
      </link>
    </plugin>

    <!-- Body -->
    <link name="base_link">
      <inertial>
        <mass>147.8671</mass>
        <inertia>
          <ixx>3.0</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>41.980233</iyy>
          <iyz>0</iyz>
          <izz>41.980233</izz>
        </inertia>
      </inertial>

      <collision name="main_body_buoyancy">
        <geometry>
          <mesh>
            <uri>meshes/tethys.dae</uri>
          </mesh>
        </geometry>
      </collision>

      <visual name="visual">
        <geometry>
          <mesh>
            <uri>meshes/tethys.dae</uri>
            <submesh>
              <name>Body</name>
              <center>false</center>
            </submesh>
          </mesh>
        </geometry>
        <material>
          <diffuse>1.0 1.0 1.0</diffuse>
          <specular>1.0 1.0 1.0</specular>
        </material>
      </visual>

      <!-- Camera -->
      <link name="camera_link">
        <pose>0.5 0 1.5 0 0 0</pose> <!-- Position of the camera relative to the base_link -->
        <sensor name="camera" type="camera">
          <camera>
            <horizontal_fov>1.047</horizontal_fov>
            <image>
              <width>640</width>
              <height>480</height>
              <format>R8G8B8</format>
            </image>
            <clip>
              <near>0.1</near>
              <far>100.0</far>
            </clip>
          </camera>
          <plugin name="camera_controller" filename="libignition-gazebo-camera-plugin.so"/>
        </sensor>
      </link>

    </link>

    <!-- Horizontal Fins -->
    <link name="horizontal_fins">
      <pose>1.05 0 0 0 0 0</pose>
      <inertial>
        <mass>0.2</mass>
        <inertia>
          <ixx>0.0007924568755</ixx>
          <iyy>0.0010546736475</iyy>
          <izz>0.0002633558262</izz>
        </inertia>
      </inertial>
      <collision name="collision">
        <geometry>
          <mesh>
            <uri>meshes/tethys.dae</uri>
            <submesh>
              <name>Fins_Horizontal</name>
              <center>false</center>
            </submesh>
          </mesh>
        </geometry>
      </collision>
      <visual name="visual">
        <geometry>
          <mesh>
            <uri>meshes/tethys.dae</uri>
            <submesh>
              <name>Fins_Horizontal</name>
              <center>false</center>
            </submesh>
          </mesh>
        </geometry>
      </visual>
    </link>

    <!-- Vertical Fins -->
    <link name="vertical_fins">
      <pose>1.05 0 0 0 0 0</pose>
      <inertial>
        <mass>0.2</mass>
        <inertia>
          <ixx>0.0007924568755</ixx>
          <iyy>0.0010546736475</iyy>
          <izz>0.0002633558262</izz>
        </inertia>
      </inertial>
      <collision name="collision">
        <geometry>
          <mesh>
            <uri>meshes/tethys.dae</uri>
            <submesh>
              <name>Fins_Vertical</name>
              <center>false</center>
            </submesh>
          </mesh>
        </geometry>
      </collision>
      <visual name="visual">
        <geometry>
          <mesh>
            <uri>meshes/tethys.dae</uri>
            <submesh>
              <name>Fins_Vertical</name>
              <center>false</center>
            </submesh>
          </mesh>
        </geometry>
      </visual>
    </link>

    <!-- Propeller -->
    <link name="propeller">
      <pose>1.43162 0 0 0 0 0</pose>
      <inertial>
        <mass>0.09</mass>
        <inertia>
          <ixx>0.000143971303</ixx>
          <iyy>0.000140915448</iyy>
          <izz>0.000033571862</izz>
        </inertia>
      </inertial>
      <collision name="collision">
        <geometry>
          <mesh>
            <uri>meshes/tethys.dae</uri>
            <submesh>
              <name>Prop</name>
              <center>false</center>
            </submesh>
          </mesh>
        </geometry>
      </collision>
      <visual name="visual">
        <geometry>
          <mesh>
            <uri>meshes/tethys.dae</uri>
            <submesh>
              <name>Prop</name>
              <center>false</center>
            </submesh>
          </mesh>
        </geometry>
      </visual>
    </link>

    <!-- Joints -->
    <joint name="horizontal_fins_joint" type="revolute">
      <parent>base_link</parent>
      <child>horizontal_fins</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-0.261799</lower>
          <upper>0.261799</upper>
        </limit>
      </axis>
    </joint>

    <joint name="vertical_fins_joint" type="revolute">
      <parent>base_link</parent>
      <child>vertical_fins</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-0.261799</lower>
          <upper>0.261799</upper>
        </limit>
      </axis>
    </joint>

    <joint name="propeller_joint" type="revolute">
      <parent>base_link</parent>
      <child>propeller</child>
      <axis>
        <xyz>1 0 0</xyz>
        <limit>
          <lower>-1e+12</lower>
          <upper>1e+12</upper>
        </limit>
      </axis>
    </joint>
  </model>
</sdf>

